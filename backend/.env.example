# Server Configuration
PORT=3001
# Must be "production" in production: it masks 500 error details from clients
# and keeps the /api/auth/dev endpoint disabled (it only accepts
# NODE_ENV=development or test).
NODE_ENV=development

# Database
# Must point at the same database as bot/.env's MONGODB_URI - the backend shares
# the bot's `userlevels` collection for coin balances and the daily-bonus claim.
MONGODB_URI=mongodb://localhost:27017/gnome

# Authentication
JWT_SECRET=your-super-secret-jwt-key-here

# Discord Configuration
# Get these from Discord Developer Portal: https://discord.com/developers/applications
# Required for Discord Activity OAuth authentication
DISCORD_CLIENT_ID=your-discord-client-id
DISCORD_CLIENT_SECRET=your-discord-client-secret
# Use HTTPS for local development (Discord requires https://localhost:*)
# Also the sole allowed CORS origin for both REST and Socket.io - point it at
# the deployed frontend origin in production.
DISCORD_ACTIVITY_URL=https://localhost:3000
{
  "name": "gnome",
  "version": "1.0.0",
  "description": "A discord bot linked to n8n",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "start:prod": "node --max-old-space-size=512 dist/index.js",
    "dev": "ts-node index.ts",
    "deploy": "npm run build && node dist/deploy-commands.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@discordjs/voice": "^0.19.0",
    "@distube/ytdl-core": "^4.16.12",
    "@ffmpeg-installer/ffmpeg": "^1.1.0",
    "@snazzah/davey": "^0.1.7",
    "@types/node-cron": "^3.0.11",
    "discord.js": "^14.15.2",
    "dotenv": "^17.2.3",
    "ffmpeg-static": "^5.2.0",
    "libsodium": "^0.7.15",
    "mongoose": "^8.19.2",
    "node-cron": "^4.2.1",
    "opusscript": "^0.0.8",
    "play-dl": "^1.9.7",
    "prism-media": "^1.3.5",
    "undici": "^6.18.1",
    "youtube-sr": "^4.3.12",
    "youtubei.js": "^16.0.1",
    "ytdl-core": "^4.11.5"
  },
  "devDependencies": {
    "@types/libsodium-wrappers": "^0.7.14",
    "@types/node": "^24.9.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}

DISCORD_TOKEN=your_discord_bot_token_here
DISCORD_CLIENT_ID=your_client_id_here
DISCORD_GUILD_ID=your_guild_id_here
MISTRAL_API_KEY=your_mistral_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
RIOT_GAMES_API_KEY=your_riot_games_api_key_here

# MongoDB Connection
# For MongoDB Atlas: mongodb+srv://username:password@cluster.mongodb.net/gnome
# For local MongoDB: mongodb://localhost:27017/gnome
# Must match backend/.env's MONGODB_URI - the backend's Discord Activity casino
# reads/writes coins and the daily-bonus claim on this same `userlevels` collection.
MONGODB_URI=mongodb://localhost:27017/gnome

# Music Service Configuration
# Set to 'true' to use native Linux yt-dlp instead of npm packages for music
# Requires yt-dlp to be installed on the system: sudo apt install yt-dlp
# or: pip install yt-dlp
USE_YTDLP=false
# Frontend Environment Variables
# Copy this to .env.local and configure as needed

# Backend API URL (default: proxied via Vite)
VITE_API_URL=http://localhost:3001

# WebSocket URL (default: proxied via Vite)
VITE_WS_URL=http://localhost:3001

# Discord Client ID (REQUIRED for Discord Activity mode)
# Get this from Discord Developer Portal: https://discord.com/developers/applications
VITE_DISCORD_CLIENT_ID=your_discord_client_id

# Development Mode (enables auto-deletion of test characters)
# Set to "true" to enable dev mode features (character reset on creation page)
# Set to "false" or remove in production to preserve user data
VITE_DEV_MODE=true
